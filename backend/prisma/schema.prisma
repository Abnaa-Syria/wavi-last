datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPPORT
  CUSTOMER
}

enum Permission {
  // Products
  PRODUCT_CREATE
  PRODUCT_UPDATE
  PRODUCT_DELETE
  PRODUCT_VIEW

  // Orders
  ORDER_VIEW
  ORDER_UPDATE
  ORDER_CANCEL
  ORDER_FULFILL

  // Users
  USER_VIEW
  USER_UPDATE
  USER_BAN

  // Coupons
  COUPON_CREATE
  COUPON_UPDATE
  COUPON_DELETE

  // Categories
  CATEGORY_CREATE
  CATEGORY_UPDATE
  CATEGORY_DELETE

  // Settings
  SETTINGS_MANAGE

  // Reports
  REPORTS_VIEW

  // Delivery
  DELIVERY_MANAGE

  // Support
  SUPPORT_MANAGE
}

enum ProductType {
  SUBSCRIPTION    // Falcon, Universe, Smarters, Hulk, Vulture, IBO
  DIGITAL_FILE    // PDF books → auto-delivery
  GAME_CURRENCY   // FC26 coins, game top-ups
  SOCIAL_SERVICE  // Instagram / Snapchat services
  PHYSICAL        // Xiaomi TV Box
}

enum DeliveryMethod {
  AUTO_FILE       // رابط تحميل فوري (كتب PDF)
  WHATSAPP        // بيانات اشتراك عبر واتساب
  ACTIVATION_CODE // كود تفعيل (IBO Player)
  MANUAL          // تنفيذ يدوي من الفريق (شحن ألعاب، سوشيال)
  SHIPPING        // توصيل فيزيائي (Xiaomi Box)
}

enum OrderStatus {
  PENDING         // بعد الدفع، في انتظار التجهيز
  PROCESSING      // الفريق شغّال عليه
  FULFILLED       // تم التسليم / التفعيل
  CANCELLED       // ملغي
  REFUNDED        // مُسترجع
  FAILED          // فشل في التنفيذ
  WAITING_INFO    // في انتظار بيانات العميل
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  MADA
  CREDIT_CARD
  APPLE_PAY
  TABBY        // تقسيط
  TAMARA       // تقسيط
  EMKAN        // تقسيط
  COD          // للطلبات الفيزيائية مستقبلاً
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  RETURNED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  SENT
  FAILED
  PENDING
}

enum MediaType {
  IMAGE
  VIDEO
  FILE
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerifiedAt   DateTime?
  phone             String?   @unique
  phoneVerifiedAt   DateTime?
  passwordHash      String
  firstName         String
  lastName          String
  avatarUrl         String?
  isActive          Boolean   @default(true)
  isBanned          Boolean   @default(false)
  banReason         String?
  role              Role      @default(CUSTOMER)
  preferredLang     String    @default("ar")
  country           String?
  city              String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime? // soft delete

  // Relations
  rolePermissions   UserRolePermission[]
  sessions          Session[]
  addresses         Address[]
  orders            Order[]
  reviews           Review[]
  wishlist          Wishlist[]
  notifications     Notification[]
  supportTickets    SupportTicket[]       @relation("CustomerTickets")
  assignedTickets   SupportTicket[]       @relation("AgentTickets")
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]

  @@index([email])
  @@index([phone])
  @@index([role])
}

model UserRolePermission {
  id         String     @id @default(cuid())
  userId     String
  permission Permission

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  label        String? // "البيت"، "العمل"
  fullName     String
  phone        String
  country      String  @default("SA")
  city         String
  district     String?
  street       String?
  buildingNo   String?
  postalCode   String?
  isDefault    Boolean @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
}

// ============================================================
// CATALOG — Categories & Products
// ============================================================

model Category {
  id           String     @id @default(cuid())
  nameAr       String
  nameEn       String?
  slug         String     @unique
  descriptionAr String?
  descriptionEn String?
  imageUrl     String?
  iconUrl      String?
  parentId     String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  isFeatured   Boolean    @default(false)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  parent       Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryTree")
  products     Product[]

  @@index([slug])
  @@index([parentId])
}

model Product {
  id               String         @id @default(cuid())
  sku              String         @unique
  nameAr           String
  nameEn           String?
  slug             String         @unique
  shortDescAr      String?        @db.Text
  shortDescEn      String?        @db.Text
  descriptionAr    String?        @db.Text
  descriptionEn    String?        @db.Text
  productType      ProductType
  deliveryMethod   DeliveryMethod
  categoryId       String

  // Pricing — base price (variants override this)
  basePrice        Decimal        @db.Decimal(10, 2)
  compareAtPrice   Decimal?       @db.Decimal(10, 2) // السعر قبل الخصم
  currency         String         @default("SAR")

  // Inventory (for physical products)
  trackInventory   Boolean        @default(false)
  stockQty         Int?
  lowStockThreshold Int?

  // Flags
  isActive         Boolean        @default(true)
  isFeatured       Boolean        @default(false)
  isDigital        Boolean        @default(true)
  requiresInfo     Boolean        @default(false) // هل يحتاج بيانات إضافية؟
  geoRestricted    Boolean        @default(false) // مثل هولك: لا يعمل في الإمارات
  restrictedCountries Json?

  // SEO
  metaTitleAr      String?
  metaDescAr       String?
  metaTitleEn      String?
  metaDescEn       String?

  // For digital files (كتب PDF)
  fileUrl          String?        // encrypted / signed URL
  fileKey          String?        // S3 key

  // Delivery notes shown to customer
  deliveryNoteAr   String?
  deliveryNoteEn   String?

  // Internet requirement (for streaming subscriptions)
  minInternetSpeed Int?           // Mbps

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?      // soft delete

  // Relations
  category         Category       @relation(fields: [categoryId], references: [id])
  variants         ProductVariant[]
  media            ProductMedia[]
  features         ProductFeature[]
  compatibleDevices ProductDevice[]
  activationSteps  ActivationStep[]
  orderItems       OrderItem[]
  reviews          Review[]
  wishlist         Wishlist[]
  cartItems        CartItem[]
  requiredFields   ProductRequiredField[]
  tags             ProductTag[]
  relatedProducts  ProductRelation[]       @relation("MainProduct")
  relatedTo        ProductRelation[]       @relation("RelatedProduct")
  bundleItems      BundleItem[]            @relation("BundleProduct")
  bundles          BundleItem[]            @relation("ChildProduct")

  @@index([slug])
  @@index([categoryId])
  @@index([productType])
  @@index([isActive, isFeatured])
}

// Variants — e.g. "Smarters 15 شهر / مستخدم واحد"
model ProductVariant {
  id               String   @id @default(cuid())
  productId        String
  sku              String   @unique
  nameAr           String   // "15 شهر - مستخدم واحد"
  nameEn           String?
  price            Decimal  @db.Decimal(10, 2)
  compareAtPrice   Decimal? @db.Decimal(10, 2)
  durationMonths   Int?     // مدة الاشتراك بالشهور
  devicesCount     Int?     // عدد الأجهزة
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  stockQty         Int?     // للمنتجات الفيزيائية أو المحدودة

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  cartItems        CartItem[]

  @@index([productId])
}

model ProductMedia {
  id          String    @id @default(cuid())
  productId   String
  mediaType   MediaType @default(IMAGE)
  url         String
  altAr       String?
  altEn       String?
  sortOrder   Int       @default(0)
  isPrimary   Boolean   @default(false)

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductFeature {
  id        String  @id @default(cuid())
  productId String
  textAr    String
  textEn    String?
  icon      String? // emoji or icon name
  sortOrder Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductDevice {
  id        String  @id @default(cuid())
  productId String
  nameAr    String  // "أجهزة iPhone وiPad"
  nameEn    String?

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ActivationStep {
  id        String  @id @default(cuid())
  productId String
  stepNo    Int
  textAr    String
  textEn    String?

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// Dynamic required fields per product
// e.g. FC26 coins needs: Platform, Game ID, Server
// Social services needs: profileUrl, quantity, speed
model ProductRequiredField {
  id           String  @id @default(cuid())
  productId    String
  fieldKey     String  // "platform" | "gameId" | "profileUrl" | "quantity"
  labelAr      String
  labelEn      String?
  placeholder  String?
  fieldType    String  @default("text") // text | select | number | textarea
  options      Json?                    // للحقول من نوع select
  isRequired   Boolean @default(true)
  sortOrder    Int     @default(0)

  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, fieldKey])
  @@index([productId])
}

model Tag {
  id       String       @id @default(cuid())
  nameAr   String
  nameEn   String?
  slug     String       @unique
  products ProductTag[]
}

model ProductTag {
  productId String
  tagId     String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model ProductRelation {
  mainProductId    String
  relatedProductId String

  mainProduct      Product @relation("MainProduct", fields: [mainProductId], references: [id])
  relatedProduct   Product @relation("RelatedProduct", fields: [relatedProductId], references: [id])

  @@id([mainProductId, relatedProductId])
}

// Bundle products (e.g. Xiaomi Box + اشتراك)
model Bundle {
  id          String       @id @default(cuid())
  nameAr      String
  nameEn      String?
  price       Decimal      @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  items       BundleItem[]
}

model BundleItem {
  id          String   @id @default(cuid())
  bundleId    String
  productId   String
  quantity    Int      @default(1)

  bundle      Bundle   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product     Product  @relation("BundleProduct", fields: [productId], references: [id])
  childProducts Product[] @relation("ChildProduct")

  @@index([bundleId])
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique // WAVI-2026-00001
  userId           String
  addressId        String?       // للمنتجات الفيزيائية
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(PENDING)

  // Pricing
  subtotal         Decimal       @db.Decimal(10, 2)
  shippingCost     Decimal       @db.Decimal(10, 2) @default(0)
  discountAmount   Decimal       @db.Decimal(10, 2) @default(0)
  taxAmount        Decimal       @db.Decimal(10, 2) @default(0)
  total            Decimal       @db.Decimal(10, 2)
  currency         String        @default("SAR")

  // Coupon
  couponId         String?
  couponCode       String?

  // Contact info (للتواصل بعد الشراء)
  customerPhone    String?       // واتساب العميل
  customerWhatsapp String?
  customerNotes    String?

  // Admin notes
  adminNotes       String?

  // Fulfillment
  fulfilledAt      DateTime?
  cancelledAt      DateTime?
  cancellationReason String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User          @relation(fields: [userId], references: [id])
  address          Address?      @relation(fields: [addressId], references: [id])
  coupon           Coupon?       @relation(fields: [couponId], references: [id])
  items            OrderItem[]
  payment          Payment?
  shipment         Shipment?
  statusHistory    OrderStatusHistory[]
  notifications    Notification[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  variantId       String?
  quantity        Int      @default(1)
  unitPrice       Decimal  @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)

  // Snapshot of product at time of purchase
  productNameAr   String
  productNameEn   String?
  variantNameAr   String?
  productType     ProductType
  deliveryMethod  DeliveryMethod

  // Customer-provided data for this item
  // (e.g. gameId, platform, profileUrl, whatsapp)
  customerData    Json?         // flexible key-value

  // Delivery output
  deliveryData    Json?         // بيانات التفعيل / رابط الملف / الكود
  deliveredAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdBy String?     // userId of admin/system
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ============================================================
// PAYMENT
// ============================================================

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("SAR")

  // Gateway response
  gatewayName     String?       // "tabby" | "tamara" | "moyasar"
  gatewayRef      String?       // معرف العملية عند البوابة
  gatewayResponse Json?

  paidAt          DateTime?
  refundedAt      DateTime?
  refundAmount    Decimal?      @db.Decimal(10, 2)
  refundReason    String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order           Order         @relation(fields: [orderId], references: [id])
  installments    PaymentInstallment[]

  @@index([orderId])
  @@index([gatewayRef])
}

model PaymentInstallment {
  id          String   @id @default(cuid())
  paymentId   String
  installmentNo Int
  amount      Decimal  @db.Decimal(10, 2)
  dueDate     DateTime
  paidAt      DateTime?
  status      String   @default("PENDING")

  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

// ============================================================
// SHIPPING (Physical Products)
// ============================================================

model ShippingZone {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String?
  countries   Json?
  cities      Json?
  isActive    Boolean  @default(true)

  rates        ShippingRate[]
}

model ShippingRate {
  id          String       @id @default(cuid())
  zoneId      String
  nameAr      String
  nameEn      String?
  price       Decimal      @db.Decimal(10, 2) @default(0)
  minWeight   Decimal?     @db.Decimal(10, 3) // kg
  maxWeight   Decimal?     @db.Decimal(10, 3)
  minOrderAmt Decimal?     @db.Decimal(10, 2) // free shipping threshold
  isFree      Boolean      @default(false)
  isActive    Boolean      @default(true)

  zone        ShippingZone @relation(fields: [zoneId], references: [id])
}

model Shipment {
  id              String         @id @default(cuid())
  orderId         String         @unique
  carrier         String?        // "aramex" | "smsa" | ...
  trackingNumber  String?
  trackingUrl     String?
  status          ShipmentStatus @default(PENDING)
  estimatedDelivery DateTime?
  deliveredAt     DateTime?
  notes           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order           Order          @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

// ============================================================
// PROMOTIONS
// ============================================================

model Coupon {
  id              String     @id @default(cuid())
  code            String     @unique
  descriptionAr   String?
  type            CouponType
  value           Decimal    @db.Decimal(10, 2) // % or fixed amount
  minOrderAmount  Decimal?   @db.Decimal(10, 2)
  maxUses         Int?       // null = unlimited
  usedCount       Int        @default(0)
  maxUsesPerUser  Int?       @default(1)
  isActive        Boolean    @default(true)
  startsAt        DateTime?
  expiresAt       DateTime?

  // Scope
  applicableToAll Boolean    @default(true)
  categoryIds     Json?
  productIds      Json?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  orders          Order[]
  usages          CouponUsage[]

  @@index([code])
  @@index([isActive])
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String
  usedAt    DateTime @default(now())

  coupon    Coupon   @relation(fields: [couponId], references: [id])

  @@unique([couponId, userId, orderId])
  @@index([couponId])
  @@index([userId])
}

model Sale {
  id          String    @id @default(cuid())
  nameAr      String
  nameEn      String?
  discountPct Decimal   @db.Decimal(5, 2) // خصم بالنسبة المئوية
  isActive    Boolean   @default(true)
  startsAt    DateTime
  expiresAt   DateTime

  productIds  Json?
  categoryIds Json?

  createdAt   DateTime  @default(now())
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id         String       @id @default(cuid())
  userId     String
  productId  String
  orderId    String?
  rating     Int          // 1-5
  titleAr    String?
  bodyAr     String?
  status     ReviewStatus @default(PENDING)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user       User         @relation(fields: [userId], references: [id])
  product    Product      @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@index([status])
}

// ============================================================
// WISHLIST & CART
// ============================================================

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  addedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique // null = guest (by sessionId)
  sessionId String?    @unique
  currency  String     @default("SAR")
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())

  items     CartItem[]

  @@index([userId])
  @@index([sessionId])
}

model CartItem {
  id           String   @id @default(cuid())
  cartId       String
  productId    String
  variantId    String?
  quantity     Int      @default(1)
  customerData Json?    // pre-fill required fields
  addedAt      DateTime @default(now())

  cart         Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

// ============================================================
// SUPPORT TICKETS
// ============================================================

model SupportTicket {
  id          String         @id @default(cuid())
  ticketNo    String         @unique // TICKET-00001
  customerId  String
  agentId     String?
  orderId     String?
  subject     String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  channel     String         @default("whatsapp") // whatsapp | email | web

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  resolvedAt  DateTime?
  closedAt    DateTime?

  customer    User           @relation("CustomerTickets", fields: [customerId], references: [id])
  agent       User?          @relation("AgentTickets", fields: [agentId], references: [id])
  messages    TicketMessage[]

  @@index([customerId])
  @@index([agentId])
  @@index([status])
  @@index([ticketNo])
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String   // userId
  body        String
  attachments Json?
  isInternal  Boolean  @default(false) // internal note بين الأدمن والسبورت
  createdAt   DateTime @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String              @id @default(cuid())
  userId    String
  orderId   String?
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  titleAr   String?
  bodyAr    String
  data      Json?               // extra payload
  sentAt    DateTime?
  readAt    DateTime?

  createdAt DateTime            @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?              @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([status])
}

// ============================================================
// CMS — Banners & Pages & FAQs
// ============================================================

model Banner {
  id          String    @id @default(cuid())
  titleAr     String?
  titleEn     String?
  imageUrl    String
  mobileImageUrl String?
  linkUrl     String?
  placement   String    @default("hero") // hero | category | sidebar
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  startsAt    DateTime?
  expiresAt   DateTime?

  createdAt   DateTime  @default(now())
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique // "about", "privacy-policy", "return-policy"
  titleAr     String
  titleEn     String?
  contentAr   String   // rich text / markdown
  contentEn   String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model FaqCategory {
  id        String @id @default(cuid())
  nameAr    String
  nameEn    String?
  sortOrder Int    @default(0)
  isActive  Boolean @default(true)

  faqs      Faq[]
}

model Faq {
  id          String      @id @default(cuid())
  categoryId  String?
  questionAr  String
  questionEn  String?
  answerAr    String
  answerEn    String?
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)

  category    FaqCategory? @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

model Testimonial {
  id          String   @id @default(cuid())
  nameAr      String
  avatarUrl   String?
  bodyAr      String
  rating      Int      @default(5)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
}

// ============================================================
// SETTINGS & AUDIT
// ============================================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general") // general | payment | whatsapp | seo
  updatedAt DateTime @updatedAt

  @@index([group])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // "ORDER_FULFILLED", "PRODUCT_UPDATED", ...
  entityType String   // "Order", "Product", ...
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
